{
  "name": "chart-docsite",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": [],
  "tags": ["platform:web", "vNext", "charting"],
  "targets": {
    "build-storybook": {
      "dependsOn": [
        {
          "projects": ["react-storybook-addon", "react-storybook-addon-export-to-sandbox", "storybook-llms-extractor"],
          "target": "build"
        }
      ]
    },
    "deploy-website": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cross-env DEPLOY_PATH=/charts/ yarn nx run chart-docsite:build-storybook -o ../public-docsite-v9/dist/storybook/charts"
      }
    }
  }
}
